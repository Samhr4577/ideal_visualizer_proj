{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": ["Dockerfile", "backend/**", "src/**"]
  },
  "deploy": {
    "startCommand": "serve -s dist -l 3000",
    "rootDirectory": "./",
    "numReplicas": 1,
    "sleepOnIdle": false
  }
}
